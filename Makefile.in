
CFLAGS=-march=native -Ofast -g -flto -std=gnu99 -W -pedantic -Wcast-qual -Wpointer-arith -Wcast-align \
	-mavx2 -mfma -ffast-math @CFLAGS@ @FFTW_CFLAGS@

LDFLAGS=@LDFLAGS@ @FFTW_LIBS@ -lm -lpthread

cCC=@CC@


all: kpfft_test

%.o: %.c
	$(cCC) -c $(CFLAGS) -o $@ $<

kpfft_test: kpfft_test.o kpfft_lib.o my_thr_lib.o aff.o
	$(cCC) -Wall -o $@ $^ $(LDFLAGS)


.PHONY: clean distclean

clean:
	rm -f *.o

distclean: clean 
	rm kpfft_test



